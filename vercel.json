{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd client && npm ci && npm run build",
  "outputDirectory": "client/dist",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.resumerush.io" }],
      "destination": "https://resumerush.io/$1",
      "permanent": true
    }
  ]
}
